# ── Copy this file to ".env" and fill in what you have. ───────────────────────
# The app works without keys (template-merge fallback), but AI generation is best
# with a key. It tries ANTHROPIC first, then OPENAI.

# Anthropic (preferred). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (fallback, used only if ANTHROPIC_API_KEY is empty or fails)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Server
PORT=4000
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated origins allowed in dev (Vite runs on 5173)
CLIENT_ORIGIN=http://localhost:5173
