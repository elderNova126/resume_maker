{
  "name": "resume-maker",
  "version": "1.0.0",
  "private": true,
  "description": "AI resume maker + job search aggregator (file-based, no database)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "serve": "npm run build && npm run start",
    "postinstall": "node server/scripts/ensure-dirs.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^2.2.0",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "vite": "^6.0.7"
  }
}
